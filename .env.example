# Copy to .env.local and fill in. On Vercel, set the SAME variables under
# Project → Settings → Environment Variables and enable them for ALL
# environments (Production, Preview, Development) — if they're scoped to
# Production only, Preview deploys crash with a 500 from proxy.ts.

# --- Supabase (Project → Settings → API) ---------------------------------
# Public project URL and publishable (anon) key. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Secret (service-role) key — SERVER ONLY. Bypasses RLS; used by the pre-auth
# PIN lookup and `pnpm seed`. Never prefix with NEXT_PUBLIC_ / expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Public site URL -----------------------------------------------------
# Canonical origin used to build absolute share links (https://planr.page/share/<token>).
# Set this in Vercel PRODUCTION ONLY. Leave it unset for local dev and Preview
# deploys so links fall back to the current host (localhost / the preview URL).
NEXT_PUBLIC_SITE_URL=https://planr.page

# --- Members ------------------------------------------------------------
# The two members. Each maps to a pre-provisioned Supabase auth user;
# emails/passwords are used server-side to sign in once the typed nickname (and
# PIN, if set) is verified. NAME is the nickname seeded for that member.
MEMBER_A_NAME=Alex
MEMBER_A_EMAIL=alex@example.com
MEMBER_A_PASSWORD=change-me

MEMBER_B_NAME=Sam
MEMBER_B_EMAIL=sam@example.com
MEMBER_B_PASSWORD=change-me

# --- MCP server (Claude connector) --------------------------------------
# Exposes calendar/tasks/insights to Claude (claude.ai, Desktop, Code) over a
# remote MCP endpoint at /api/mcp, OAuth-secured by Supabase's OAuth server.
# Off by default; flip to "true" to mount the endpoint.
MCP_ENABLED=false
# Redis connection (TCP, redis:// or rediss://) — REQUIRED when MCP_ENABLED.
# mcp-handler uses it for streamable-HTTP session state across serverless
# instances. On Vercel, add the Upstash/Redis Marketplace integration (fra1) and
# it sets REDIS_URL automatically; locally use a dev Upstash URL or
# `redis://localhost:6379`.
REDIS_URL=
# Optional explicit public origin for OAuth resource metadata. Defaults to the
# request origin (NEXT_PUBLIC_SITE_URL in prod). Set only if behind a proxy that
# strips the standard forwarding headers.
# MCP_RESOURCE_URL=https://planr.page
